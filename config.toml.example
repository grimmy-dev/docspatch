# docspatch config — copy to ~/.docspatch/config.toml

[defaults]
style = "compact"               # compact | detailed
model = "gemini-2.0-flash"      # cheap model for docstring generation
review_model = "gemini-2.5-pro" # stronger model for code review

[keys]
# Provide one key — docspatch uses whichever is present
# openai_api_key = "sk-..."
# anthropic_api_key = "sk-ant-..."
# google_api_key = "AIza..."
